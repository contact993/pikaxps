            <svg width="17" height="17" viewBox="0 0 24 24" fill="#E9EEF6"><path d="M3 5.4 10.5 4.3V11H3ZM12 4.1 21 3v8H12ZM3 12.5h7.5V19L3 17.9ZM12 12.5h9V21l-9-1.3Z"/></svg>
            ${t.ctaWin}
          </a>
        </div>
        <div style="margin-top:24px;font-family:'IBM Plex Mono';font-size:12px;color:#5E6B7C;letter-spacing:.04em">${t.ctaNote}<a href="${FEAT}" style="color:#9AA7B8;text-decoration:none">${t.ctaNoteLink}</a></div>
        <div style="margin-top:22px;padding-top:20px;border-top:1px solid rgba(255,255,255,.08);display:flex;gap:18px;align-items:center;justify-content:center;flex-wrap:wrap;font-size:13.5px">
          <span style="color:#9AA7B8">${t.ctaSupport}</span>
          <a href="${GH}" class="cp-btn-ghost" style="display:inline-flex;align-items:center;gap:7px;text-decoration:none;color:#E9EEF6;font-family:'Space Grotesk';font-weight:600;font-size:14px;padding:8px 15px;border-radius:9px;border:1px solid rgba(255,255,255,.14)">${t.ctaStar}</a>
          <a href="${CITE}" class="cp-btn-ghost" style="display:inline-flex;align-items:center;gap:7px;text-decoration:none;color:#E9EEF6;font-family:'Space Grotesk';font-weight:600;font-size:14px;padding:8px 15px;border-radius:9px;border:1px solid rgba(255,255,255,.14)">${t.ctaCite}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="border-top:1px solid rgba(255,255,255,.07);background:#080A0F">
    <div class="cp-foot-grid" style="max-width:1200px;margin:0 auto;padding:48px 24px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:32px">
      <div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
          ${logo(24)}
          <span style="font-family:'Space Grotesk';font-weight:700;font-size:18px">PikaXPS</span>
        </div>
        <p style="color:#5E6B7C;font-size:13.5px;max-width:280px;line-height:1.6;margin:0">${t.footTagline}</p>
      </div>
      <div>
        <div style="font-family:'IBM Plex Mono';font-size:11px;letter-spacing:.1em;color:#5E6B7C;margin-bottom:14px">${t.footProduct}</div>
        <div style="display:flex;flex-direction:column;gap:11px">
          <a href="#features" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footFeatures}</a>
          <a href="${DL}" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footDownload}</a>
          <a href="${GUIDE}" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footGuide}</a>
        </div>
      </div>
      <div>
        <div style="font-family:'IBM Plex Mono';font-size:11px;letter-spacing:.1em;color:#5E6B7C;margin-bottom:14px">${t.footProject}</div>
        <div style="display:flex;flex-direction:column;gap:11px">
          <a href="${GH}" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">GitHub</a>
          <a href="${CITE}" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footCite}</a>
          <a href="${GH}/discussions" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footDiscussions}</a>
          <a href="${GH}" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footLicense}</a>
        </div>
      </div>
      <div>
        <div style="font-family:'IBM Plex Mono';font-size:11px;letter-spacing:.1em;color:#5E6B7C;margin-bottom:14px">${t.footCompare}</div>
        <div style="display:flex;flex-direction:column;gap:11px">
          <a href="#compare" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footVsXps}</a>
          <a href="#compare" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footVsCasa}</a>
          <a href="#auditor" class="cp-navlink" style="color:#9AA7B8;text-decoration:none;font-size:14px">${t.footAuditor}</a>
        </div>
      </div>
    </div>
    <div style="max-width:1200px;margin:0 auto;padding:18px 24px 40px;border-top:1px solid rgba(255,255,255,.05);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:'IBM Plex Mono';font-size:11.5px;color:#5E6B7C">
      <span>${t.footCopyright}</span>
      <span>${t.footComments}</span>
    </div>
  </footer>
`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.htmlTitle}</title>
    <meta name="description" content={t.metaDesc} />
    <link rel="canonical" href={Astro.site ? new URL(lang === 'ko' ? `${BASE}ko/` : BASE, Astro.site).href : docBase} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={t.htmlTitle} />
    <meta property="og:description" content={t.metaDesc} />
    <meta property="og:image" content={`${BASE}screenshot.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${BASE}screenshot.png`} />
    <meta
      name="keywords"
      content="XPS, X-ray photoelectron spectroscopy, peak fitting, curve fitting, XPSPEAK alternative, CasaXPS alternative, free XPS software, surface analysis, Mac"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'PikaXPS',
      applicationCategory: 'ScienceApplication',
      operatingSystem: 'macOS, Windows',
      description: t.metaDesc,
      downloadUrl: `${GH}/releases`,
      license: 'https://www.gnu.org/licenses/gpl-3.0.html',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      author: { '@type': 'Person', name: 'Taehee Kim' },
    })} />
    <style is:global>
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: #07090D; }
      ::selection { background: rgba(37, 99, 235, .28); color: #fff; }
      @keyframes cpPulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .35; transform: scale(.7); } }
      @keyframes cpFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
      @keyframes cpDash { to { stroke-dashoffset: -220; } }
      a { transition: color .18s ease, background .18s ease, transform .18s ease, gap .18s ease; }
      .cp-navlink:hover { color: #E9EEF6 !important; }
      .cp-star:hover { background: rgba(255, 255, 255, .05); }
      .cp-btn-primary:hover { background: #3b82f6 !important; transform: translateY(-1px); }
      .cp-btn-ghost:hover { background: rgba(255, 255, 255, .09) !important; }
      .cp-card { transition: border-color .18s ease, transform .18s ease; }
      .cp-card:hover { transform: translateY(-2px); }
      .cp-card--blue:hover { border-color: rgba(37, 99, 235, .35) !important; }
      .cp-card--azure:hover { border-color: rgba(96, 165, 250, .35) !important; }
      .cp-card--violet:hover { border-color: rgba(167, 139, 250, .35) !important; }
      .cp-card--amber:hover { border-color: rgba(251, 191, 36, .35) !important; }
      .cp-seehow:hover { gap: 12px !important; }
      .cp-cmp-scroll { overflow-x: auto; }
      @media (max-width: 860px) {
        .cp-grid2 { grid-template-columns: 1fr !important; gap: 28px !important; }
        .cp-h1 { font-size: 44px !important; }
        .cp-h2 { font-size: 32px !important; }
        .cp-foot-grid { grid-template-columns: 1fr 1fr !important; }
        .cp-navlinks { display: none !important; }
      }
      @media (max-width: 520px) {
        .cp-h1 { font-size: 36px !important; }
        .cp-foot-grid { grid-template-columns: 1fr !important; }
        .cp-star { display: none !important; }
      }
    </style>
  </head>
  <body>
    <div
      style="background:#07090D;color:#E9EEF6;font-family:'IBM Plex Sans',system-ui,sans-serif;min-height:100vh;position:relative;overflow:hidden;-webkit-font-smoothing:antialiased;line-height:1.5"
    >
      <Fragment set:html={body} />
    </div>
  </body>
</html>
