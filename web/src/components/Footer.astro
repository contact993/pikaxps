---
// Custom Starlight footer: default footer + a Star/Cite support block + Giscus comments.
//
// PikaXPS is 100% free with NO ads. On every documentation page we instead place a
// tasteful, privacy-clean nudge toward the two things that actually sustain a free
// academic tool: a GitHub star and a citation. Both are plain links — no tracking.
import Default from '@astrojs/starlight/components/Footer.astro';

const pathname = Astro.url.pathname;                 // e.g. /pikaxps/ko/cite/
const isKo = /\/ko(\/|$)/.test(pathname);
const isSplash = Astro.props.entry?.data?.template === 'splash';
const show = !isSplash;

const GH = 'https://github.com/contact993/pikaxps';
const T = isKo
  ? {
      lead: 'PikaXPS가 연구에 도움이 됐나요?',
      body: '무료 학술 도구의 지속 개발을 정당화하는 건 ⭐ GitHub Star와 논문 인용입니다. 1초면 됩니다.',
      star: '⭐ GitHub에서 Star',
      cite: '📑 인용 방법',
      citeHref: '/pikaxps/ko/cite/',
      comments: '댓글 · 질문',
      ns1: '댓글은 GitHub Discussions 기반입니다 — ',
      nsLink: '게시판 열기',
    }
  : {
      lead: 'Did PikaXPS help your research?',
      body: 'A GitHub star and a citation are how a free academic tool justifies its continued development. Both take one second.',
      star: '⭐ Star on GitHub',
      cite: '📑 How to cite',
      citeHref: '/pikaxps/cite/',
      comments: 'Comments & questions',
      ns1: 'Comments are powered by GitHub Discussions — ',
      nsLink: 'open the board',
    };
---

<Default {...Astro.props}><slot /></Default>

{show && (
  <div class="cp-extras">
    <aside class="cp-support">
      <p class="cp-support-lead">{T.lead}</p>
      <p class="cp-support-body">{T.body}</p>
      <p class="cp-support-cta">
        <a href={GH}>{T.star}</a>
        <span aria-hidden="true">·</span>
        <a href={T.citeHref}>{T.cite}</a>
      </p>
    </aside>

    {/* Giscus comments (GitHub Discussions). Fill repo-id / category-id from giscus.app
        once Discussions is configured; until then the noscript fallback links the board. */}
    <section class="cp-comments" aria-label="Comments">
      <h2>{T.comments}</h2>
      <script
        src="https://giscus.app/client.js"
        data-repo="contact993/pikaxps"
        data-repo-id="REPLACE_ME"
        data-category="General"
        data-category-id="REPLACE_ME"
        data-mapping="pathname"
        data-strict="1"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="preferred_color_scheme"
        data-lang={isKo ? 'ko' : 'en'}
        crossorigin="anonymous"
        async
      ></script>
      <noscript>
        {T.ns1}<a href={`${GH}/discussions`}>{T.nsLink}</a>.
      </noscript>
    </section>
  </div>
)}

<style>
  .cp-extras { margin-top: 2rem; }
  .cp-support {
    margin: 1.5rem 0;
    border: 1px solid var(--sl-color-gray-5);
    border-left: 3px solid var(--sl-color-accent);
    border-radius: 0.5rem;
    padding: 0.9rem 1.1rem;
    background: var(--sl-color-gray-6);
  }
  .cp-support-lead { margin: 0; font-weight: 600; font-size: var(--sl-text-base); }
  .cp-support-body { margin: 0.3rem 0 0.6rem; font-size: var(--sl-text-sm); color: var(--sl-color-gray-2); }
  .cp-support-cta { margin: 0; display: flex; gap: 0.7rem; align-items: center; flex-wrap: wrap; }
  .cp-support-cta a { font-weight: 600; font-size: var(--sl-text-sm); }
  .cp-comments { margin-top: 2rem; border-top: 1px solid var(--sl-color-gray-5); padding-top: 1.5rem; }
  .cp-comments h2 { font-size: var(--sl-text-h4); margin-bottom: 1rem; }
</style>
